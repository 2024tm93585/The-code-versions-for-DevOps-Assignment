pipeline {
    agent any

    environment {
        PROJECT_DIR    = "DevOps-Assignment2"
        PYTHON         = "python3"
        VENV_DIR       = "${WORKSPACE}/DevOps-Assignment2/venv"
        AWS_REGION     = "${env.AWS_REGION ?: 'us-east-1'}"
        ECR_REPO       = "${env.ECR_REPO ?: 'aceest-fitness'}"
        IMAGE_TAG      = "${env.BUILD_NUMBER}"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    stages {

        // --------------------------------------------------------
        stage('Checkout') {
        // --------------------------------------------------------
            steps {
                echo '=== Stage 1: Checkout ==='
                checkout scm
                echo "Branch  : ${env.GIT_BRANCH ?: 'local'}"
                echo "Commit  : ${env.GIT_COMMIT ?: 'local'}"
                echo "Workspace: ${WORKSPACE}"
            }
        }

        // --------------------------------------------------------
        stage('Install Dependencies') {
        // --------------------------------------------------------
            steps {
                echo '=== Stage 2: Install Dependencies ==='
                sh """
                    cd ${PROJECT_DIR}
                    ${PYTHON} -m venv venv
                    . venv/bin/activate
                    pip install --upgrade pip
                    pip install -r requirements.txt
                """
            }
        }

        // --------------------------------------------------------
        stage('Code Quality — Flake8') {
        // --------------------------------------------------------
            steps {
                echo '=== Stage 3: Lint with Flake8 ==='
                sh """
                    cd ${PROJECT_DIR}
                    . venv/bin/activate
                    flake8 app/ tests/ --max-line-length=120 --statistics --count
                """
            }
        }

        // --------------------------------------------------------
        stage('Unit Tests — Pytest') {
        // --------------------------------------------------------
            steps {
                echo '=== Stage 4: Run Pytest with Coverage ==='
                sh """
                    cd ${PROJECT_DIR}
                    . venv/bin/activate
                    pytest tests/ -v \\
                        --cov=app \\
                        --cov-report=xml:coverage.xml \\
                        --cov-report=html:htmlcov \\
                        --junitxml=test-results.xml
                """
            }
            post {
                always {
                    // Publish JUnit test results (built-in, no plugin needed)
                    junit allowEmptyResults: true,
                          testResults: "${PROJECT_DIR}/test-results.xml"

                    // Archive all artifacts (built-in)
                    archiveArtifacts artifacts: "${PROJECT_DIR}/test-results.xml, ${PROJECT_DIR}/coverage.xml, ${PROJECT_DIR}/htmlcov/**",
                                     allowEmptyArchive: true
                }
            }
        }

        // --------------------------------------------------------
        stage('SonarQube Analysis') {
        // --------------------------------------------------------
            steps {
                echo '=== Stage 5: SonarQube Analysis ==='
                sh """
                    export PATH=\$PATH:/opt/homebrew/bin
                    cd ${PROJECT_DIR}
                    . venv/bin/activate

                    sonar-scanner \\
                        -Dsonar.projectKey=aceest-fitness \\
                        -Dsonar.projectName="ACEest Fitness & Gym" \\
                        -Dsonar.projectVersion=3.2.4 \\
                        -Dsonar.sources=app \\
                        -Dsonar.tests=tests \\
                        -Dsonar.python.coverage.reportPaths=coverage.xml \\
                        -Dsonar.python.xunit.reportPath=test-results.xml \\
                        -Dsonar.host.url=http://localhost:9000 \\
                        -Dsonar.token=squ_a35560238f9004afa2a6dc4f85510fca0acd8024 \\
                        -Dsonar.sourceEncoding=UTF-8
                """
            }
        }

        // --------------------------------------------------------
        stage('Build Docker Image') {
        // --------------------------------------------------------
            steps {
                echo '=== Stage 6: Build Docker Image ==='
                sh """
                    # Use full path to docker since Jenkins has restricted PATH
                    export PATH=\$PATH:/usr/local/bin:/Applications/Docker.app/Contents/Resources/bin

                    cd ${PROJECT_DIR}
                    docker build --platform linux/amd64 \\
                        -t aceest-fitness:${IMAGE_TAG} \\
                        -t aceest-fitness:latest \\
                        .
                    echo "Built: aceest-fitness:${IMAGE_TAG}"
                    docker images aceest-fitness
                """
            }
        }

        // --------------------------------------------------------
        stage('Deploy to Docker Desktop') {
        // --------------------------------------------------------
            steps {
                echo '=== Stage 7: Deploy to Docker Desktop ==='
                sh """
                    export PATH=\$PATH:/usr/local/bin:/Applications/Docker.app/Contents/Resources/bin

                    # Stop and remove existing container if running
                    docker stop aceest-fitness-app 2>/dev/null || true
                    docker rm   aceest-fitness-app 2>/dev/null || true

                    # Run new container from freshly built image
                    docker run -d \\
                        --name aceest-fitness-app \\
                        --platform linux/amd64 \\
                        -p 5000:5000 \\
                        -e FLASK_ENV=production \\
                        --restart unless-stopped \\
                        aceest-fitness:latest

                    echo "Container started"
                    docker ps --filter name=aceest-fitness-app
                """
            }
        }

        // --------------------------------------------------------
        stage('Smoke Test — Docker Desktop') {
        // --------------------------------------------------------
            steps {
                echo '=== Stage 8: Smoke Test ==='
                sh """
                    # Wait for Flask to start inside container
                    sleep 5

                    # Hit the health endpoint
                    curl -f --retry 5 --retry-delay 3 http://localhost:5000/health
                    echo ""
                    echo "Smoke test passed — app is live at http://localhost:5000"
                """
            }
        }

        // --------------------------------------------------------
        stage('Push to ECR') {
        // --------------------------------------------------------
            when {
                allOf {
                    expression { return sh(script: 'which docker', returnStatus: true) == 0 }
                    expression { return sh(script: 'which aws', returnStatus: true) == 0 }
                    branch 'main'
                }
            }
            steps {
                echo '=== Stage 7: Push to Amazon ECR ==='
                sh """
                    AWS_ACCOUNT_ID=\$(aws sts get-caller-identity --query Account --output text)
                    ECR_URI=\${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPO}
                    aws ecr get-login-password --region ${AWS_REGION} | \\
                        docker login --username AWS --password-stdin \${ECR_URI}
                    docker tag aceest-fitness:${IMAGE_TAG} \${ECR_URI}:${IMAGE_TAG}
                    docker tag aceest-fitness:${IMAGE_TAG} \${ECR_URI}:latest
                    docker push \${ECR_URI}:${IMAGE_TAG}
                    docker push \${ECR_URI}:latest
                    docker logout
                    echo "Pushed: \${ECR_URI}:${IMAGE_TAG}"
                """
            }
        }

        // --------------------------------------------------------
        stage('Deploy to AWS ECS') {
        // --------------------------------------------------------
            when {
                allOf {
                    expression { return sh(script: 'which aws', returnStatus: true) == 0 }
                    branch 'main'
                }
            }
            steps {
                echo '=== Stage 8: Deploy to ECS Fargate ==='
                sh """
                    chmod +x ${PROJECT_DIR}/aws/deploy-ecs.sh
                    bash ${PROJECT_DIR}/aws/deploy-ecs.sh
                """
            }
        }

    }

    // --------------------------------------------------------
    post {
    // --------------------------------------------------------
        always {
            echo '=== Pipeline Complete ==='
            echo "Build #${BUILD_NUMBER} finished — ${currentBuild.currentResult}"
        }
        success {
            echo '✅ All stages passed successfully!'
        }
        failure {
            echo '❌ Pipeline failed — check logs above'
            // Rollback: restart previous container if available
            sh """
                echo "Rolling back Docker container..."
                docker stop aceest-fitness-app 2>/dev/null || true
                docker rm   aceest-fitness-app 2>/dev/null || true

                # Restart from previous image tag if it exists
                PREV_TAG=\$(( ${IMAGE_TAG} - 1 ))
                if docker image inspect aceest-fitness:\${PREV_TAG} > /dev/null 2>&1; then
                    docker run -d \\
                        --name aceest-fitness-app \\
                        -p 5000:5000 \\
                        -e FLASK_ENV=production \\
                        --restart unless-stopped \\
                        aceest-fitness:\${PREV_TAG}
                    echo "Rolled back to aceest-fitness:\${PREV_TAG}"
                else
                    echo "No previous image found — manual intervention required"
                fi

                # Also rollback ECS if AWS is available
                if which aws > /dev/null 2>&1; then
                    aws ecs update-service \\
                        --cluster aceest-cluster \\
                        --service aceest-fitness-service \\
                        --force-new-deployment \\
                        --region ${AWS_REGION} || true
                    echo "ECS rollback triggered"
                fi
            """
        }
    }
}
